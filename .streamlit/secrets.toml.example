# NCDA ローカル自動化ハブ 秘匿情報サンプル
#
# 使い方:
#   このファイルを `secrets.toml` にコピーして、実際の値に書き換える。
#   secrets.toml は .gitignore 対象なのでリポジトリには含まれない。
#
# Streamlit 側で st.secrets[...] で読み込まれる。

[github]
# fine-grained PAT 推奨。必要最小権限: Issues(Write)、Metadata(Read)
token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
default_repo = "umetani/jlac10-mapping"
# GHE で動かす場合: 例 "https://ghe.example.com/api/v3"
# GitHub.com 用なら省略可（デフォルト https://api.github.com）
api_base = "https://api.github.com"
# 自己署名証明書の GHE なら "false" にする（文字列で指定）
verify_tls = "true"

[rocketchat]
url = "https://10.152.72.7"

# 方式A: Personal Access Token（推奨、パスワード変更の影響を受けない）
auth_token = ""
user_id = ""

# 方式B: user + password（簡易、開発用）
user = "umetani"
password = ""

default_room = "umetani"
default_mention = "@koakutu"

[power_automate]
# キー = ベンダー別 Webhook エイリアス、値 = 発火URL
# ペイロードJSON 側で {"power_automate":{"webhook_key":"vendor_fujitsu"}} と指定
vendor_fujitsu = ""
vendor_nec = ""
vendor_ssi = ""
vendor_sbs = ""
vendor_khi = ""
vendor_ibm = ""
vendor_csi = ""
vendor_nais = ""
